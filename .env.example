# Spotify
SPOTIFY_CLIENT_ID=tu_client_id_aqui
SPOTIFY_CLIENT_SECRET=tu_client_secret_aqui
SPOTIFY_PLAYLIST_ID=tu_playlist_id_aqui
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
# Obtenlo corriendo: python scripts/get_spotify_token.py
SPOTIFY_REFRESH_TOKEN=tu_refresh_token_aqui

# Telegram
TELEGRAM_BOT_TOKEN=tu_token_aqui

# Google Sheets
GOOGLE_SHEET_ID=tu_sheet_id_aqui
# Pega el JSON completo de la cuenta de servicio (en una sola línea) O usa la ruta al archivo
GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Control de envío: 'test' = a ti mismo, 'main' = a ella
RECIPIENT_OVERRIDE=test
